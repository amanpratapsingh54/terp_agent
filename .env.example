# Copy this file to .env and fill in your values.
# .env is auto-loaded on server start (see api/routers/agent.py).

# Required to upgrade Testudo from heuristic mode to real Claude tool-use.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-5-20250929. Use claude-haiku-4-5-20251001
# for cheaper/faster responses, or claude-opus-4-6 for the strongest reasoning.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
